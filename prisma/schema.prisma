generator client {
  provider = "prisma-client-js"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  COMPANY
  APPLICANT
  ADMIN
}

enum EmploymentType {
  FULL_TIME
  PART_TIME
  CONTRACT
  INTERNSHIP
}

enum JobStatus {
  ACTIVE
  PAUSED
  CLOSED
}

enum ApplicationStatus {
  APPLIED
  SCREENING
  SHORTLISTED
  INTERVIEWED
  SELECTED
  REJECTED
}

enum InterviewStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum Recommendation {
  HIRE
  MAYBE
  REJECT
}

// User model - base for all users
model User {
  id            String    @id @default(uuid())
  email         String    @unique
  image         String?
  passwordHash  String?   @map("password_hash")
  role          Role
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  // Relations
  company       Company?
  applicant     Applicant?
  notifications Notification[]

  @@map("users")
}

// Company model
model Company {
  id                 String   @id @default(uuid())
  userId             String   @unique @map("user_id")
  name               String
  industry           String?
  size               String?
  location           String?
  description        String?  @db.Text
  website            String?
  logoUrl            String?  @map("logo_url")
  onboardingComplete Boolean  @default(false) @map("onboarding_complete")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @default(now()) @updatedAt @map("updated_at")

  // Relations
  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobs       Job[]
  assistants Assistant[]

  @@map("companies")
}

// Assistant model - AI interviewers
model Assistant {
  id              String   @id @default(uuid())
  companyId       String   @map("company_id")
  name            String
  vapiAssistantId String   @unique @map("vapi_assistant_id")
  provider        String // "openai", "anthropic", etc.
  model           String // "gpt-4-turbo", "claude-3-5-sonnet-20241022", etc.
  voiceProvider   String   @map("voice_provider") // "11labs", "openai", etc.
  voice           String // Voice ID
  firstMessage    String   @db.Text @map("first_message")
  systemPrompt    String   @db.Text @map("system_prompt")
  endMessage      String?  @db.Text @map("end_message") // Optional end message
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  // Relations
  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  jobs    Job[]

  @@map("assistants")
}

// Applicant model
model Applicant {
  id                 String   @id @default(uuid())
  userId             String   @unique @map("user_id")
  fullName           String   @map("full_name")
  phone              String?
  location           String?
  currentTitle       String?  @map("current_title")
  experience         String? // e.g., "3-5 years", "5-10 years"
  skills             String[] // Array of skills
  cvUrl              String?  @map("cv_url")
  cvParsedData       Json?    @map("cv_parsed_data")
  onboardingComplete Boolean  @default(false) @map("onboarding_complete")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @default(now()) @updatedAt @map("updated_at")

  // Relations
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  applications Application[]
  savedJobs    SavedJob[]

  @@map("applicants")
}

model SavedJob {
  id          String    @id @default(uuid())
  applicantId String    @map("applicant_id")
  jobId       String    @map("job_id")
  createdAt   DateTime  @default(now()) @map("created_at")

  // Relations
  applicant   Applicant @relation(fields: [applicantId], references: [id], onDelete: Cascade)
  job         Job       @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@unique([applicantId, jobId])
  @@map("saved_jobs")
}

enum JobLocationType {
  REMOTE
  ONSITE
  HYBRID
}

// Job model
model Job {
  id                 String          @id @default(uuid())
  companyId          String          @map("company_id")
  assistantId        String?         @map("assistant_id") // Optional until assigned
  title              String
  description        String?         @db.Text
  location           String?
  locationType       JobLocationType @default(ONSITE) @map("location_type")
  employmentType     EmploymentType  @map("employment_type")
  salaryRange        String?         @map("salary_range")
  criteria           Json // {skills: [], experience: 3, education: "Bachelor"}
  shortlistThreshold Int             @default(70) @map("shortlist_threshold") 
  interviewQuestions Json?           @map("interview_questions")
  status             JobStatus       @default(ACTIVE)
  createdAt          DateTime        @default(now()) @map("created_at")
  updatedAt          DateTime        @updatedAt @map("updated_at")

  // Relations
  company      Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  assistant    Assistant?    @relation(fields: [assistantId], references: [id])
  applications Application[]
  savedBy      SavedJob[]

  @@map("jobs")
}

// Application model
model Application {
  id           String            @id @default(uuid())
  jobId        String            @map("job_id")
  applicantId  String            @map("applicant_id")
  cvUrl        String            @map("cv_url")
  status       ApplicationStatus @default(APPLIED)
  matchScore   Decimal?          @map("match_score") @db.Decimal(5, 2) // 0-100
  matchDetails Json?             @map("match_details") // {matched_skills: [], missing_skills: []}
  createdAt    DateTime          @default(now()) @map("created_at")
  updatedAt    DateTime          @updatedAt @map("updated_at")

  // Relations
  job       Job         @relation(fields: [jobId], references: [id], onDelete: Cascade)
  applicant Applicant   @relation(fields: [applicantId], references: [id], onDelete: Cascade)
  interview Interview?

  @@unique([jobId, applicantId])
  @@map("applications")
}

// Interview model
model Interview {
  id                String          @id @default(uuid())
  applicationId     String          @unique @map("application_id")
  scheduledAt       DateTime?       @map("scheduled_at")
  startedAt         DateTime?       @map("started_at")
  endedAt           DateTime?       @map("ended_at")
  durationMinutes   Int?            @map("duration_minutes")
  meetingLink       String?         @map("meeting_link")
  vapiCallId        String?         @map("vapi_call_id")
  vapiAssistantId   String?         @map("vapi_assistant_id")
  status            InterviewStatus @default(SCHEDULED)
  createdAt         DateTime        @default(now()) @map("created_at")

  // Relations
  application     Application      @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  interviewReport InterviewReport?

  @@map("interviews")
}

// Interview Report model
model InterviewReport {
  id                   String         @id @default(uuid())
  interviewId          String         @unique @map("interview_id")
  transcript           Json // [{role: "assistant", content: "..."}, ...]
  technicalScore       Decimal        @map("technical_score") @db.Decimal(5, 2) // 0-100
  communicationScore   Decimal        @map("communication_score") @db.Decimal(5, 2)
  overallScore         Decimal        @map("overall_score") @db.Decimal(5, 2)
  strengths            String[]
  weaknesses           String[]
  recommendation       Recommendation
  summary              String         @db.Text
  analysisData         Json           @map("analysis_data") // Full GPT-4 response
  createdAt            DateTime       @default(now()) @map("created_at")

  // Relations
  interview Interview @relation(fields: [interviewId], references: [id], onDelete: Cascade)

  @@map("interview_reports")
}

// Notification model
model Notification {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  type      String // 'interview_scheduled', 'application_update', etc.
  title     String
  message   String   @db.Text
  read      Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

// OTP Verification model
model OTPVerification {
  id           String   @id @default(uuid())
  email        String
  otp          String // Hashed OTP
  attempts     Int      @default(0)
  signupData   Json? // Temporary storage for signup data
  expiresAt    DateTime @map("expires_at")
  verified     Boolean  @default(false)
  createdAt    DateTime @default(now()) @map("created_at")

  @@index([email])
  @@map("otp_verifications")
}
